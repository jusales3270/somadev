GEMINI_API_KEY=your_gemini_api_key_here

# Optional: API Key for authenticating requests to SomaDev API
# If set, all /chat and /execute endpoints will require this key in X-API-Key header
SOMADEV_API_KEY=your_somadev_api_key_here

# Optional: Allowed CORS origins (comma separated)
# Default: http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: Base paths for agents (useful for deployment)
# Default: relative paths from project root
SOMADEV_FRONTEND_PATH=./frontend/src
SOMADEV_BACKEND_PATH=./backend
